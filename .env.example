# LIQAA Meet — environment

# The public domain users will reach the app on.
# Examples: meet.example.com  ·  localhost:3000
MEET_DOMAIN=localhost:3000
MEET_PORT=3000

# SQLite by default. Drop in a Postgres URL for production.
# postgres://user:pass@host:5432/meet
DATABASE_URL=file:/data/meet.db

# ─── LIQAA video infrastructure ──────────────────────────────────────────
# Get free keys at https://liqaa.io/console (1,000 min/mo on free tier).
# Or run your own LIQAA self-host (see hartemyaakoub/liqaa-architecture).
LIQAA_API_BASE=https://api.liqaa.io
LIQAA_PK=pk_live_replace_me
LIQAA_SK=sk_live_replace_me
LIQAA_WEBHOOK_SECRET=whsec_replace_me

# ─── Features ────────────────────────────────────────────────────────────
FEATURE_CAPTIONS=true
FEATURE_SUMMARY=true
FEATURE_RECORDING=false

# ─── LLM (used for post-call summary) ────────────────────────────────────
# Provider: ollama  ·  openai  ·  anthropic  ·  any-openai-compatible
LLM_PROVIDER=ollama
LLM_MODEL=llama3.2:3b
LLM_BASE_URL=http://ollama:11434
LLM_API_KEY=

# ─── Branding (optional) ─────────────────────────────────────────────────
BRAND_NAME=LIQAA Meet
BRAND_PRIMARY=#1d4ed8
BRAND_LOGO_URL=
